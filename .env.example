# INEGI DENUE: token de la API oficial (https://www.inegi.org.mx/servicios/api_denue.html).
DENUE_TOKEN=

# Scraper de señales (scraping/news): tope de notas a enriquecer por corrida. 0 = solo sitemap
# (sin leer <head>, sin asunto). Opcional; por defecto 150. Ver scraping/README.md.
SCRAPE_ENRICH_LIMIT=

# Smoke test del contrato de APIs (scripts/verify-api.mjs). Opcional; por defecto http://localhost:3000.
ECOSISTEMA_BASE_URL=

# NOTA: EU no usa base de datos propia — la persistencia es de OIS (ver docs/spec-integracion-eu-ois_v1.md).
# Por eso NO existe DATABASE_URL: el esquema PostGIS de docs/ es histórico/superado.

# Mercado Libre API oficial (dato inmobiliario por municipio/CP). App gratuita en
# https://developers.mercadolibre.com.mx . Opción simple para pruebas: pega un access token (dura 6 h).
ML_ACCESS_TOKEN=
# Producción (mintea access token vía refresh). OJO: el refresh_token de ML rota en cada uso →
# persistirlo es trabajo de OIS (worker + DB); en MVP usa ML_ACCESS_TOKEN.
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REFRESH_TOKEN=

# OIS — plataforma que aporta memoria/continuidad/operación (https://github.com/ois-institucional/ois).
# EU envía la señal ciudadana a la PUERTA pública de OIS (POST /public/site/{slug}/contact). Sin esto,
# la captura degrada honesto al canal de WhatsApp. OIS_TENANT_SLUG = tenant de EU en OIS.
# Ver docs/spec-integracion-eu-ois_v1.md.
OIS_BASE_URL=
OIS_TENANT_SLUG=ecosistemaurbano
